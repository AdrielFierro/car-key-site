---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import { brand } from '../../config/brand';
import { client } from '../../data/client';

const whatsappHref = `https://wa.me/54${client.phoneForTel}?text=${encodeURIComponent(
  'Hola! Necesito cerrajería automotor en Castelar / Zona Oeste. ¿Me ayudás?'
)}`;
---

<BaseLayout
  title="Contacto"
  description={`Contactá a ${brand.name} por WhatsApp o teléfono. Zona Oeste (Castelar y alrededores).`}
>
  <Header slot="header" />

  <Banner title="Contacto" />

  <section class="py-section">
    <div class="mx-auto grid max-w-site grid-cols-1 gap-10 px-4 sm:px-6 lg:grid-cols-5 lg:gap-14">

      <!-- Form -->
      <div class="lg:col-span-3">
        <h2 class="font-heading text-h2 font-bold uppercase text-text">Mandanos un mensaje</h2>
        <p class="mt-2 mb-8 text-text-muted">
          Completá el formulario y te respondemos a la brevedad.
        </p>

        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/contact/success"
          class="flex flex-col gap-5"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden" aria-hidden="true">
            <label>Leave this empty: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </p>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Nombre <span class="text-accent" aria-hidden="true">*</span></span>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Email <span class="text-accent" aria-hidden="true">*</span></span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Teléfono</span>
            <input
              type="tel"
              name="phone"
              autocomplete="tel"
              inputmode="tel"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Mensaje <span class="text-accent" aria-hidden="true">*</span></span>
            <textarea
              name="message"
              rows="5"
              required
              class="min-h-[120px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 resize-y"
            ></textarea>
          </label>

          <button
            type="submit"
            class="mt-2 inline-flex min-h-[44px] cursor-pointer items-center justify-center self-start rounded-md bg-accent px-8 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
          >
            Enviar
          </button>
        </form>
      </div>

      <!-- Contact info sidebar -->
      <aside class="space-y-8 lg:col-span-2">
        <div>
          <h3 class="font-heading text-lg font-semibold text-text">Llamanos</h3>
          <a href={`tel:${client.phoneForTel}`} class="mt-1 block text-primary-light font-medium transition-colors hover:text-primary">
            {client.phoneFormatted}
          </a>
        </div>

        <div>
          <h3 class="font-heading text-lg font-semibold text-text">WhatsApp</h3>
          <a
            href={whatsappHref}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-1 inline-flex min-h-[44px] items-center justify-center rounded-md bg-primary px-5 py-2.5 text-sm font-bold text-primary-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
          >
            Escribir por WhatsApp
          </a>
          <p class="mt-2 text-sm text-text-muted">
            Zona Oeste: Castelar y alrededores.
          </p>
        </div>

        {client.email && (
          <div>
            <h3 class="font-heading text-lg font-semibold text-text">Email</h3>
            <a href={`mailto:${client.email}`} class="mt-1 block text-primary-light font-medium transition-colors hover:text-primary">
              {client.email}
            </a>
          </div>
        )}

        {client.address.mapLink && (
          <div>
            <h3 class="font-heading text-lg font-semibold text-text">Ubicación</h3>
            <a
              href={client.address.mapLink}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-1 block text-text-muted transition-colors hover:text-text"
            >
              {client.address.lineOne}<br />
              {client.address.lineTwo && <>{client.address.lineTwo}<br /></>}
              {client.address.city}, {client.address.state} {client.address.zip}
            </a>
          </div>
        )}

        <div>
          <h3 class="font-heading text-lg font-semibold text-text">Horarios</h3>
          <p class="mt-1 text-text-muted">
            Urgencias: hasta las 19:00<br />
            <span class="font-medium text-accent">Apertura de autos • Llaves codificadas • Programación</span>
          </p>
        </div>
      </aside>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
